<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Required for Electron hardenedRuntime -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>

  <!-- Screen capture — required for desktopCapturer (screen share) -->
  <key>com.apple.security.device.screen-capture</key>
  <true/>

  <!-- Camera and microphone — required for video/voice calls -->
  <key>com.apple.security.device.camera</key>
  <true/>
  <key>com.apple.security.device.microphone</key>
  <true/>

  <!-- Network access — required for chat connections -->
  <key>com.apple.security.network.client</key>
  <true/>

  <!-- File access — for file sharing and attachments -->
  <key>com.apple.security.files.user-selected.read-write</key>
  <true/>

  <!-- Notifications -->
  <key>com.apple.security.app-sandbox</key>
  <false/>
</dict>
</plist>
