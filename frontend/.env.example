# nself-chat Environment Variables
# =============================================================================
#
# This is the root .env.example file showing minimal configuration.
#
# For detailed examples, see:
# - Frontend: frontend/apps/web/examples/.env.*.example
# - Backend: backend/.env.example
#
# =============================================================================

# Environment
NODE_ENV=development

# Backend URLs (provided by nself CLI)
NEXT_PUBLIC_GRAPHQL_URL=http://api.localhost/v1/graphql
NEXT_PUBLIC_AUTH_URL=http://auth.localhost/v1/auth
NEXT_PUBLIC_STORAGE_URL=http://storage.localhost/v1/storage

# Optional: Enable development mode with test users
# NEXT_PUBLIC_USE_DEV_AUTH=true

# App Configuration
NEXT_PUBLIC_APP_NAME=nchat
NEXT_PUBLIC_PRIMARY_COLOR=#6366f1

# ─────────────────────────────────────────────────────────────────────────────
# nChat Bundle — Pro Plugin Feature Flags
# These are set automatically when nChat bundle plugins are installed via:
#   nself license set nself_pro_xxxxxxxxxxxxxxxxxxxxxxxx
#   nself plugin install chat livekit recording moderation bots realtime auth
#   nself build && nself start
#
# Without these vars the features are absent — the app never crashes on missing
# plugins. Each var is set to a blank comment here; uncomment and fill in when
# the corresponding plugin is installed.
# ─────────────────────────────────────────────────────────────────────────────

# chat plugin — core message store hooks, channel management, delivery status
# NEXT_PUBLIC_CHAT_ENABLED=true

# livekit plugin — WebRTC voice + video (NEXT_PUBLIC_LIVEKIT_URL presence enables feature)
# NEXT_PUBLIC_LIVEKIT_URL=wss://livekit.your-domain.com

# recording plugin — call + screen-share recording
# NEXT_PUBLIC_RECORDING_ENABLED=true

# moderation plugin — AI + rule-based message filtering
# NEXT_PUBLIC_MODERATION_ENABLED=true

# bots plugin — programmable bots + slash commands
# NEXT_PUBLIC_BOTS_ENABLED=true

# realtime plugin — presence, typing indicators, live cursors (NEXT_PUBLIC_REALTIME_URL presence enables feature)
# NEXT_PUBLIC_REALTIME_URL=wss://realtime.your-domain.com

# auth plugin (pro extension) — SSO, LDAP, SAML
# NEXT_PUBLIC_AUTH_SSO_ENABLED=false

# ─────────────────────────────────────────────────────────────────────────────
# Admin GraphQL Client — server-side secret (REQUIRED for production)
# ─────────────────────────────────────────────────────────────────────────────

# HASURA_ADMIN_SECRET is required for all production builds.
# Production builds fail at build time if this is not set.
# Use a minimum 32-character random string.
HASURA_ADMIN_SECRET=

# Development-only: allows the dummy admin secret to be used in local builds.
# Must NOT be set in any production environment.
# Requires SKIP_ENV_VALIDATION=true to also be set.
# NEXT_PUBLIC_ALLOW_DUMMY_ADMIN_SECRET=true

# For more configuration options, see:
# - backend/.env.example (backend services config + full nChat bundle docs)
