{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["vite/client", "node"],
    "paths": {
      "@/*": ["./src/*"],
      "@nself/auth-core": ["../../packages/@nself/auth-core/dist/index.d.ts"],
      "@nself/errors": ["../../packages/@nself/errors/dist/index.d.ts"],
      "@nself/graphql-client": ["../../packages/@nself/graphql-client/dist/index.d.ts"],
      "@nself/i18n": ["../../packages/@nself/i18n/dist/index.d.ts"],
      "@nself/ui": ["../../packages/@nself/ui/dist/index.d.ts"]
    }
  },
  "include": ["src", "vite.config.ts"],
  "exclude": ["node_modules", "dist"]
}
