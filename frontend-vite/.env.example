# ɳChat Vite SPA — environment template
# GraphQL (Hasura) endpoints — app talks to Hasura directly via @nself/graphql-client
VITE_GRAPHQL_URL=https://api.local.nself.org/v1/graphql
VITE_GRAPHQL_WS_URL=wss://api.local.nself.org/v1/graphql

# Dev-only auth bridge proxy target (legacy /api routes during migration)
VITE_API_PROXY_TARGET=http://localhost:3001

# Observability (optional)
VITE_SENTRY_DSN=
