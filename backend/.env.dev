# ╔═══════════════════════════════════════════════════════╗
# ║           NCHAT — DEVELOPMENT ENVIRONMENT             ║
# ╠═══════════════════════════════════════════════════════╣
# ║ File loading order (later overrides earlier):         ║
# ║   1) .env.dev     ← THIS FILE (team defaults)         ║
# ║   2) .env.staging / .env.prod                         ║
# ║   3) .env.secrets (production secrets, not shared)    ║
# ║   4) .env         (LOCAL ONLY priority overrides)     ║
# ╚═══════════════════════════════════════════════════════╝

#####################################
# Project Identity
#####################################
PROJECT_NAME=nchat
BASE_DOMAIN=local.nself.org
ENV=dev

#####################################
# Dev Secrets
# Change all of these in production.
# Move production values to .env.secrets — never commit them.
#####################################
HASURA_GRAPHQL_ADMIN_SECRET=hasura-admin-secret-dev
HASURA_JWT_KEY=nchat-development-secret-key-minimum-32-characters
MINIO_ROOT_PASSWORD=minioadmin
S3_SECRET_KEY=storage-secret-key-dev

#####################################
# Service Flags
# Required services (PostgreSQL, Hasura, Auth, Nginx) are always on.
#####################################
REDIS_ENABLED=true
MINIO_ENABLED=true
MEILISEARCH_ENABLED=true
MAILPIT_ENABLED=true
FUNCTIONS_ENABLED=false
NSELF_ADMIN_ENABLED=false
MLFLOW_ENABLED=false

#####################################
# PostgreSQL
#####################################
POSTGRES_VERSION=16-alpine
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=nchat
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres-dev-password
POSTGRES_EXTENSIONS=uuid-ossp,pgcrypto,pg_trgm,citext

#####################################
# Hasura GraphQL Engine
#####################################
HASURA_VERSION=v2.44.0
HASURA_JWT_TYPE=HS256
HASURA_GRAPHQL_ENABLE_CONSOLE=true
HASURA_GRAPHQL_DEV_MODE=true
HASURA_GRAPHQL_ENABLE_TELEMETRY=false
HASURA_GRAPHQL_CORS_DOMAIN=*
HASURA_ROUTE=api.${BASE_DOMAIN}

#####################################
# Auth Service
#####################################
AUTH_VERSION=0.36.0
AUTH_HOST=auth
AUTH_PORT=4000
AUTH_CLIENT_URL=http://localhost:3000
AUTH_JWT_SECRET=${HASURA_JWT_KEY}
AUTH_JWT_REFRESH_TOKEN_EXPIRES_IN=2592000
AUTH_JWT_ACCESS_TOKEN_EXPIRES_IN=900
AUTH_ACCESS_TOKEN_EXPIRY=15m
AUTH_REFRESH_TOKEN_EXPIRY=7d
AUTH_REFRESH_TOKEN_SECRET=${HASURA_JWT_KEY}-refresh
AUTH_WEBAUTHN_ENABLED=false
AUTH_ROUTE=auth.${BASE_DOMAIN}

# Dev email via Mailpit
AUTH_SMTP_HOST=mailpit
AUTH_SMTP_PORT=1025
AUTH_SMTP_USER=""
AUTH_SMTP_PASS=""
AUTH_SMTP_SECURE=false
AUTH_SMTP_SENDER=noreply@${BASE_DOMAIN}

#####################################
# Storage (MinIO + Hasura Storage)
#####################################
STORAGE_VERSION=0.6.1
STORAGE_ROUTE=storage.${BASE_DOMAIN}
STORAGE_CONSOLE_ROUTE=storage-console.${BASE_DOMAIN}
MINIO_VERSION=latest
MINIO_PORT=9000
MINIO_ROOT_USER=minioadmin
MINIO_DEFAULT_BUCKETS=uploads,public,private,temp,recordings
S3_ACCESS_KEY=storage-access-key-dev
S3_BUCKET=nchat
S3_REGION=us-east-1

#####################################
# Nginx
#####################################
NGINX_VERSION=alpine
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
NGINX_CLIENT_MAX_BODY_SIZE=100M
NGINX_GZIP_ENABLED=true

#####################################
# SSL (local dev)
#####################################
SSL_MODE=local

#####################################
# Email (dev — Mailpit local SMTP trap)
#####################################
EMAIL_PROVIDER=mailpit
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025
MAILPIT_ROUTE=mail.${BASE_DOMAIN}

#####################################
# Search (MeiliSearch)
#####################################
MEILISEARCH_VERSION=v1.5
MEILISEARCH_PORT=7700
MEILI_ENV=development
MEILI_NO_ANALYTICS=true
SEARCH_ENABLED=true
SEARCH_PROVIDER=meilisearch
SEARCH_AUTO_INDEX=true
SEARCH_LANGUAGE=en

#####################################
# Frontend — Core Chat (always on)
#####################################
NEXT_PUBLIC_CHAT_ENABLED=true

#####################################
# nChat Bundle Plugins
#
# These require a nSelf Basic license ($0.99/mo or $9.99/yr).
# Without a key, only the free core messaging surface is active.
#
#   nself license set nself_pro_xxxxxxxxxxxxxxxxxxxxxxxx
#   nself plugin install chat livekit recording moderation bots realtime auth
#   nself build && nself start
#
# Uncomment the vars below after installing the plugins.
#####################################
NSELF_PLUGIN_LICENSE_KEY=nself_pro_your_key_here

# livekit — WebRTC voice and video calls
# LIVEKIT_URL=wss://livekit.${BASE_DOMAIN}
# LIVEKIT_API_KEY=                           # set at plugin install
# LIVEKIT_API_SECRET=                        # set at plugin install
# NEXT_PUBLIC_LIVEKIT_URL=${LIVEKIT_URL}

# recording — call and screen-share recording (requires livekit)
# RECORDING_EGRESS_ENABLED=true
# RECORDING_STORAGE_BUCKET=recordings
# NEXT_PUBLIC_RECORDING_ENABLED=true

# moderation — AI-assisted and rule-based message filtering
# MODERATION_PROVIDER=auto
# MODERATION_AUTO_BAN_THRESHOLD=0.9
# NEXT_PUBLIC_MODERATION_ENABLED=true

# bots — programmable bot accounts and slash-command runtime
# BOTS_RUNTIME=node
# BOTS_MAX_CONCURRENT=16
# NEXT_PUBLIC_BOTS_ENABLED=true

# realtime — presence, typing, live cursors over WebSocket
# REALTIME_PORT=7001
# REALTIME_MAX_CONNECTIONS=10000
# NEXT_PUBLIC_REALTIME_URL=wss://realtime.${BASE_DOMAIN}

# auth (pro extension) — SSO, LDAP, SAML enforcement
# AUTH_SSO_ENABLED=false
# AUTH_LDAP_URL=
# AUTH_SAML_METADATA_URL=
# NEXT_PUBLIC_AUTH_SSO_ENABLED=false

#####################################
# Dev Settings
#####################################
LOG_LEVEL=info
NSELF_LOG_LEVEL=info
NSELF_START_MODE=smart
NSELF_HEALTH_CHECK_REQUIRED=60
NSELF_HEALTH_CHECK_TIMEOUT=60
