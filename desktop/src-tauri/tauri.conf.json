{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "nChat",
  "version": "0.0.0",
  "identifier": "org.nself.chat",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "nChat",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "visible": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' tauri: ipc: http://localhost:*; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "plugins": {
    "window-state": {
      "stateFlags": "SIZE | POSITION | MAXIMIZED | FULLSCREEN"
    },
    "autostart": {},
    "updater": {
      "endpoints": [
        "https://packages.nself.org/chat-desktop/latest-{{target}}-{{arch}}.json"
      ],
      "pubkey": ""
    },
    "deep-link": {
      "desktop": {
        "schemes": ["nchat"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "signingIdentity": null,
      "entitlements": "entitlements.plist"
    }
  }
}
