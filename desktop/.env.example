# nChat Desktop — environment variables
# Copy to .env.local for local overrides. Never commit .env.local.

# Optional: Sentry DSN for crash reporting.
# Leave blank to disable crash reporting (default in dev/CI).
SENTRY_DSN=

# Optional: override the updater endpoint (defaults to tauri.conf.json value).
# TAURI_UPDATER_ENDPOINT=https://packages.nself.org/chat-desktop/latest-{{target}}-{{arch}}.json
